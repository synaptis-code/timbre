{
  "client": {
    "$defs": {
      "Interrupt": {
        "additionalProperties": false,
        "description": "Client → serveur : stoppe le tour en cours (bouton Stop ou nouvelle prise de parole).",
        "properties": {
          "type": {
            "const": "interrupt",
            "default": "interrupt",
            "title": "Type",
            "type": "string"
          }
        },
        "title": "Interrupt",
        "type": "object"
      },
      "UserAudio": {
        "additionalProperties": false,
        "description": "Client → serveur : une prise de parole détectée par le VAD (WAV 16 kHz mono).",
        "properties": {
          "audio_b64": {
            "minLength": 1,
            "title": "Audio B64",
            "type": "string"
          },
          "format": {
            "const": "wav",
            "default": "wav",
            "title": "Format",
            "type": "string"
          },
          "type": {
            "const": "user_audio",
            "default": "user_audio",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "audio_b64"
        ],
        "title": "UserAudio",
        "type": "object"
      },
      "UserMessage": {
        "additionalProperties": false,
        "description": "Client → serveur : texte saisi au clavier.",
        "properties": {
          "text": {
            "minLength": 1,
            "title": "Text",
            "type": "string"
          },
          "type": {
            "const": "user_message",
            "default": "user_message",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "title": "UserMessage",
        "type": "object"
      }
    },
    "discriminator": {
      "mapping": {
        "interrupt": "#/$defs/Interrupt",
        "user_audio": "#/$defs/UserAudio",
        "user_message": "#/$defs/UserMessage"
      },
      "propertyName": "type"
    },
    "oneOf": [
      {
        "$ref": "#/$defs/UserMessage"
      },
      {
        "$ref": "#/$defs/UserAudio"
      },
      {
        "$ref": "#/$defs/Interrupt"
      }
    ]
  },
  "server": {
    "$defs": {
      "AiAudio": {
        "description": "Serveur → client : audio d'une phrase de la réponse, à jouer dans l'ordre reçu.\n\n`text` est la phrase nettoyée réellement synthétisée (debug/sous-titres).",
        "properties": {
          "audio_b64": {
            "title": "Audio B64",
            "type": "string"
          },
          "format": {
            "const": "mp3",
            "default": "mp3",
            "title": "Format",
            "type": "string"
          },
          "text": {
            "title": "Text",
            "type": "string"
          },
          "type": {
            "const": "ai_audio",
            "default": "ai_audio",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "audio_b64",
          "text"
        ],
        "title": "AiAudio",
        "type": "object"
      },
      "AiChunk": {
        "description": "Serveur → client : fragment de réponse en streaming. `last=True` clôt le tour.\n\n`interrupted=True` sur le fragment de clôture : le tour a été coupé, le texte\naffiché est exactement ce qui a été généré (et archivé) avant l'interruption.",
        "properties": {
          "interrupted": {
            "default": false,
            "title": "Interrupted",
            "type": "boolean"
          },
          "last": {
            "default": false,
            "title": "Last",
            "type": "boolean"
          },
          "text": {
            "title": "Text",
            "type": "string"
          },
          "type": {
            "const": "ai_chunk",
            "default": "ai_chunk",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "title": "AiChunk",
        "type": "object"
      },
      "AppState": {
        "enum": [
          "idle",
          "listening",
          "thinking",
          "speaking"
        ],
        "title": "AppState",
        "type": "string"
      },
      "ErrorMessage": {
        "description": "Serveur → client : erreur toujours visible, jamais avalée.",
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "const": "error",
            "default": "error",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorMessage",
        "type": "object"
      },
      "ModelInfo": {
        "description": "Serveur → client : modèle LLM actif (détecté automatiquement dans LM Studio).",
        "properties": {
          "model": {
            "title": "Model",
            "type": "string"
          },
          "type": {
            "const": "model_info",
            "default": "model_info",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "model"
        ],
        "title": "ModelInfo",
        "type": "object"
      },
      "StateChange": {
        "description": "Serveur → client : nouvel état de l'assistant.",
        "properties": {
          "state": {
            "$ref": "#/$defs/AppState"
          },
          "type": {
            "const": "state_change",
            "default": "state_change",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "state"
        ],
        "title": "StateChange",
        "type": "object"
      },
      "UserTranscript": {
        "description": "Serveur → client : ce que l'ASR a compris (affiché comme bulle utilisateur).",
        "properties": {
          "text": {
            "title": "Text",
            "type": "string"
          },
          "type": {
            "const": "user_transcript",
            "default": "user_transcript",
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "title": "UserTranscript",
        "type": "object"
      }
    },
    "discriminator": {
      "mapping": {
        "ai_audio": "#/$defs/AiAudio",
        "ai_chunk": "#/$defs/AiChunk",
        "error": "#/$defs/ErrorMessage",
        "model_info": "#/$defs/ModelInfo",
        "state_change": "#/$defs/StateChange",
        "user_transcript": "#/$defs/UserTranscript"
      },
      "propertyName": "type"
    },
    "oneOf": [
      {
        "$ref": "#/$defs/AiChunk"
      },
      {
        "$ref": "#/$defs/StateChange"
      },
      {
        "$ref": "#/$defs/ErrorMessage"
      },
      {
        "$ref": "#/$defs/ModelInfo"
      },
      {
        "$ref": "#/$defs/AiAudio"
      },
      {
        "$ref": "#/$defs/UserTranscript"
      }
    ]
  },
  "title": "Protocole WebSocket Timbre"
}
